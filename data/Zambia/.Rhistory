cox1 <- coxph(Surv(py, as.numeric(event)) ~ haven::as_factor(rx), data = hivfollowup)
load("~/Desktop/522/hivfollowup.RData")
library(survival)
library(survminer)
hiv <- hivfollowup
hiv$rx_fac <- haven::as_factor(hiv$rx)
hiv$event_num <- as.numeric(hiv$event)
surv_obj <- Surv(time = hiv$py, event = hiv$event_num)
##KM
fit_km <- survfit(surv_obj ~ rx_fac, data = hiv)
p <- ggsurvplot(
fit_km,
data = hiv,
risk.table = TRUE,
conf.int = FALSE,
xlab = "Person-years of follow-up",
ylab = "HIV-free survival probability",
legend.title = "Treatment",
legend.labs = c("Placebo", "TDF/FTC"),
title = "Kaplan–Meier curves of HIV-free survival by treatment arm"
)
p
cox1 <- coxph(Surv(py, as.numeric(event)) ~ haven::as_factor(rx), data = hivfollowup)
hr1  <- exp(coef(cox1))
ci1  <- exp(confint(cox1))
pval1 <- summary(cox1)$coef[, "Pr(>|z|)"]
cox1_table <- data.frame(
Variable = "FTC–TDF vs Placebo",
Hazard_Ratio = round(hr1, 2),
CI_Lower = round(ci1[1], 2),
CI_Upper = round(ci1[2], 2),
p_value = signif(pval1, 2)
)
kable(cox1_table,
caption = "Table 1. Cox Model 1: Treatment Effect on HIV Infection Risk")
cox2 <- coxph(Surv(py, as.numeric(event)) ~ haven::as_factor(rx) + vage,
data = hivfollowup)
hr2  <- exp(coef(cox2))
ci2  <- exp(confint(cox2))
pval2 <- summary(cox2)$coef[, "Pr(>|z|)"]
cox2_table <- data.frame(
Variable = c("FTC–TDF vs Placebo", "Age (per year)"),
Hazard_Ratio = round(hr2, 2),
CI_Lower = round(ci2[, 1], 2),
CI_Upper = round(ci2[, 2], 2),
p_value = signif(pval2, 2)
)
kable(cox2_table,
caption = "Table 2. Cox Model 2: Treatment and Age Effects on HIV Infection Risk")
cox_noage <- coxph(Surv(py, as.numeric(event)) ~ haven::as_factor(rx),
data = hivfollowup)
mart_res <- residuals(cox_noage, type = "martingale")
plot(hivfollowup$vage, mart_res,
xlab = "Age (years)", ylab = "Martingale residuals",
main = "Martingale residuals vs. Age")
lines(lowess(hivfollowup$vage, mart_res), col = "blue", lwd = 2)
abline(h = 0, lty = 2)
cox2 <- coxph(Surv(py, as.numeric(event)) ~ haven::as_factor(rx) + vage,
data = hivfollowup)
summary(cox2)
cox_noage <- coxph(Surv(py, as.numeric(event)) ~ haven::as_factor(rx),
data = hivfollowup)
mart_res <- residuals(cox_noage, type = "martingale")
plot(hivfollowup$vage, mart_res,
xlab = "Age (years)", ylab = "Martingale residuals",
main = "Martingale residuals vs. Age")
lines(lowess(hivfollowup$vage, mart_res), col = "blue", lwd = 2)
abline(h = 0, lty = 2)
cox2 <- coxph(Surv(py, as.numeric(event)) ~ haven::as_factor(rx) + vage,
data = hivfollowup)
hr2  <- exp(coef(cox2))
ci2  <- exp(confint(cox2))
