group_by(sim_id, admin1.name) %>%
summarise(
K_admin1 = sum(K, na.rm = TRUE),      # 这一整个 admin1 的簇数 = 所有 admin2 的簇数相加
H_admin1 = max(H, na.rm = TRUE),      # strata 数一般都是 2，取最大就好
.groups = "drop"
) %>%
mutate(
df_unfixed_admin1 = as.integer(K_admin1 - H_admin1),
df_fixed_admin1   = as.integer(K_admin1)
)
## 2) 把 admin1 的 df 回填到 all_runs 里，覆盖原来的 df
all_runs <- all_runs %>%
left_join(admin1_df, by = c("sim_id", "admin1.name")) %>%
mutate(
# 覆盖掉原来按 admin2 算的 df
df_unfixed = df_unfixed_admin1,
df_fixed   = df_fixed_admin1,
# 同时把真正用的 df_use 也一起改了
df_use = if_else(type == "unfixed", df_unfixed, df_fixed)
)
metrics <- summarise_metrics(all_runs)
## ===== 方法标签 & 颜色（仅 3 种）=====
.method3_levels <- c("all_unfixed","all_fixed","fixed_illegal_unfixed_legal")
.method3_labels <- c(
all_unfixed = "All—Unfixed",
all_fixed   = "All—Fixed",
fixed_illegal_unfixed_legal = "Fixed(Illegal)+Unfixed(Legal)"
)
.method3_colors <- c(
"all_unfixed" = "#ff7f0e",
"all_fixed"   = "#1f77b4",
"fixed_illegal_unfixed_legal" = "#2ca02c"
)
scale_method3_fill <- function() {
cols <- setNames(.method3_colors, .method3_labels)
scale_fill_manual(
values = cols,
breaks = .method3_labels,
labels = .method3_labels,  # 添加这一行
name = "Method",
drop = FALSE
)
}
p_var   <- plot_admin1_var_disc_faceted(metrics, conf_lvls)
print(p_var)
p_cov_z <- plot_admin1_cov_normal_faceted(metrics, conf_lvls)
p_cov_t <- plot_admin1_cov_t_faceted(metrics, conf_lvls)
print(p_cov_z); print(p_cov_t)
p_df    <- plot_admin1_df_t_faceted(metrics, conf_lvls)
print(p_df)
p_wz    <- plot_admin1_width_normal_faceted(metrics, conf_lvls)
p_wt    <- plot_admin1_width_t_faceted(metrics, conf_lvls)
print(p_wz);  print(p_wt)
p_sz    <- plot_admin1_is_normal_faceted(metrics, conf_lvls)
p_st    <- plot_admin1_is_t_faceted(metrics, conf_lvls)
print(p_sz);    print(p_st)
