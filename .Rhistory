### 1. 保存所有图像文件（动态命名）
# Direct模型
ggsave(paste0(indicator, "_direct_mean.png"), p_res_map_mean, width = 8, height = 6, dpi = 300)
ggsave(paste0(indicator, "_direct_ci.png"), p_res_map_ci, width = 8, height = 6, dpi = 300)
ggsave(paste0(indicator, "_fixed_direct_mean.png"), p_res_fix_map_mean, width = 8, height = 6, dpi = 300)
ggsave(paste0(indicator, "_fixed_direct_ci.png"), p_res_fix_map_ci, width = 8, height = 6, dpi = 300)
# FH模型
ggsave(paste0(indicator, "_fh_mean.png"), p_smth_map_mean, width = 8, height = 6, dpi = 300)
ggsave(paste0(indicator, "_fh_ci.png"), p_smth_map_ci, width = 8, height = 6, dpi = 300)
ggsave(paste0(indicator, "_fixed_fh_mean.png"), p_smth_fix_map_mean, width = 8, height = 6, dpi = 300)
ggsave(paste0(indicator, "_fixed_fh_ci.png"), p_smth_fix_map_ci, width = 8, height = 6, dpi = 300)
# Unit模型
ggsave(paste0(indicator, "_unit_mean.png"), p_cl_map_mean, width = 8, height = 6, dpi = 300)
ggsave(paste0(indicator, "_unit_ci.png"), p_cl_map_ci, width = 8, height = 6, dpi = 300)
### 创建组合图（两行布局）
# 第一行：所有均值图
mean_plots <- grid.arrange(
rasterGrob(readPNG(paste0(indicator, "_direct_mean.png"))),
rasterGrob(readPNG(paste0(indicator, "_fixed_direct_mean.png"))),
rasterGrob(readPNG(paste0(indicator, "_fh_mean.png"))),
rasterGrob(readPNG(paste0(indicator, "_fixed_fh_mean.png"))),
rasterGrob(readPNG(paste0(indicator, "_unit_mean.png"))),
nrow = 1,
top = textGrob(paste(toupper(indicator), "Mean Estimates by Model"), gp = gpar(fontsize = 16))
)
# 第二行：所有CI图
ci_plots <- grid.arrange(
rasterGrob(readPNG(paste0(indicator, "_direct_ci.png"))),
rasterGrob(readPNG(paste0(indicator, "_fixed_direct_ci.png"))),
rasterGrob(readPNG(paste0(indicator, "_fh_ci.png"))),
rasterGrob(readPNG(paste0(indicator, "_fixed_fh_ci.png"))),
rasterGrob(readPNG(paste0(indicator, "_unit_ci.png"))),
nrow = 1,
top = textGrob(paste(toupper(indicator), "95% CI Width by Model"), gp = gpar(fontsize = 16))
)
# 最终组合
final_plot <- grid.arrange(
mean_plots,
ci_plots,
nrow = 2,
heights = c(0.5, 0.5)
)
# 保存组合图
ggsave(paste0(indicator, "_comparison.png"), final_plot, width = 16, height = 10, dpi = 300)
