labs(title = "Fixed Direct Estimates by Admin2")
# 直接估计CI宽度地图
p_res_map_ci <- ggplot(res_map_df) +
geom_sf_pattern(  # 关键修改：使用geom_sf_pattern代替geom_sf
aes(fill = CI_width, pattern = hatch_type),  # 必须同时指定fill和pattern
pattern_fill = "black",
pattern_alpha = 1,
pattern_density = 0.05,
pattern_spacing = 0.01,
color = "black",
size = 0.1
) +
scale_fill_viridis_c(
option = "plasma",
name = "Width of\n95% CI",
direction = -1,
limits = global_ci_limits,
na.value = "grey90"
) +
scale_pattern_manual(
name = "Data Quality",
values = c("none" = "none", "low variance" = "pch", "missing" = "crosshatch"),
