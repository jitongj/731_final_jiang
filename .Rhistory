"%d Admin2s (%.2f%%) %s",
Count, Percentage,
case_when(
Description == paste("Total Admin2s in", country) ~ paste("in", country),
Description == "Admin2s with no sampled cluster" ~ "have no sampled cluster",
Description == "Admin2s with very low variance estimates (variance < 1e-30)" ~ "have very low variance estimates (variance < 1e-30)",
Description == "Admin2s with usable variance estimates (variance > 1e-30)" ~ "have usable variance estimates (variance > 1e-30)",
Description == "Admin2s containing only one sampled cluster" ~ "contain only one sampled cluster"
)
)) %>%
select(Formatted) %>%
kable("html") %>%
kable_styling(full_width = FALSE) %>%
column_spec(1, width = "100%") %>%
row_spec(0, bold = TRUE) %>%
gsub("Formatted", "Summary Statistics", .)
knitr::kable(final_summary_clean, caption = "Summary of Cluster and Admin2 Status by State")
###### Direct Estimate ######
res_ad1 <- directEST(data = data,
cluster.info = cluster.info,
admin = 1)
res_ad2 <- directEST(data = data,
cluster.info = cluster.info,
admin = 2,
aggregation = FALSE,
var.fix = FALSE)
res_ad2_fix <- directEST(data = data,
cluster.info = cluster.info,
admin = 2,
aggregation = FALSE,
var.fix = TRUE)
###### FH Estimate ######
smth_res_ad1_bym2 <- fhModel(data,
cluster.info = cluster.info,
admin.info = admin.info1,
admin = 1,
model = "bym2",
aggregation =FALSE)
bad_admin2 <- subset(res_ad2$res.admin2, direct.var < 1e-30)$admin2.name.full
bad_clusters <- subset(cluster.info$data, admin2.name.full %in% bad_admin2)$cluster
smth_res_ad2 <- fhModel(subset(data, !cluster %in% bad_clusters),
cluster.info = cluster.info,
admin.info = admin.info2,
admin = 2,
model = "bym2",
aggregation = FALSE,
var.fix = FALSE)
smth_res_ad2_fix <- fhModel(data,
cluster.info = cluster.info,
admin.info = admin.info2,
admin = 2,
model = "bym2",
aggregation = FALSE,
var.fix = TRUE)
###### Unit Estimate ######
cl_res_ad1 <- clusterModel(data=data,
cluster.info=cluster.info,
admin.info  = admin.info1,
stratification = FALSE,
model = "bym2",
admin = 1,
aggregation =FALSE,
CI = 0.95)
cl_res_ad2 <- clusterModel(data=data,
cluster.info= cluster.info,
admin.info = admin.info2,
model = "bym2",
stratification =FALSE,
admin = 2,
aggregation =FALSE,
CI = 0.95)
# 计算所有均值地图的全局范围
all_means <- c(
res_ad2$res.admin2$direct.est,
res_ad2_fix$res.admin2$direct.est,
smth_res_ad2$res.admin2$mean,
smth_res_ad2_fix$res.admin2$mean,
cl_res_ad2$res.admin2$mean
)
mean_limits <- range(all_means, na.rm = TRUE)
# 计算所有CI宽度地图的全局范围
all_ci_widths <- c(
res_ad2$res.admin2$direct.upper - res_ad2$res.admin2$direct.lower,
res_ad2_fix$res.admin2$direct.upper - res_ad2_fix$res.admin2$direct.lower,
smth_res_ad2$res.admin2$upper - smth_res_ad2$res.admin2$lower,
smth_res_ad2_fix$res.admin2$upper - smth_res_ad2_fix$res.admin2$lower,
cl_res_ad2$res.admin2$upper - cl_res_ad2$res.admin2$lower
)
global_ci_limits <- range(all_ci_widths, na.rm = TRUE)
# 提取 low variance, good variance 和 missing 的 admin2 名字
lowVar_admin2 <- res_ad2$res.admin2 %>%
filter(direct.var < 1e-30) %>%
pull(admin2.name.full)
goodVar_admin2 <- res_ad2$res.admin2 %>%
filter(direct.var > 1e-30) %>%
pull(admin2.name.full)
missing_admin2 <- unsampled_admin2$admin2.name.full
# 使用您已有的区域分类定义
area_types <- data.frame(
admin2.name.full = c(lowVar_admin2, goodVar_admin2, missing_admin2),
area_type = c(
rep("low variance", length(lowVar_admin2)),
rep("usable variance", length(goodVar_admin2)),
rep("missing", length(missing_admin2))
)
)
# 为所有结果添加区域类型（修正版）
add_area_type <- function(df) {
if(!"admin2.name.full" %in% names(df)) {
stop("Data frame does not contain 'admin2.name.full' column")
}
left_join(df, area_types, by = "admin2.name.full") %>%
mutate(area_type = factor(area_type,
levels = c("usable variance", "low variance", "missing")))
}
# 确保所有数据框都有admin2.name.full列
res_ad2$res.admin2 <- add_area_type(res_ad2$res.admin2)
res_ad2_fix$res.admin2 <- add_area_type(res_ad2_fix$res.admin2)
smth_res_ad2$res.admin2 <- add_area_type(smth_res_ad2$res.admin2)
smth_res_ad2_fix$res.admin2 <- add_area_type(smth_res_ad2_fix$res.admin2)
cl_res_ad2$res.admin2 <- add_area_type(cl_res_ad2$res.admin2)
res_map_df <- poly.adm2 %>%
left_join(res_ad2[["res.admin2"]], by = "admin2.name.full") %>%
mutate(
CI_width = direct.upper - direct.lower,
hatch_type = case_when(
admin2.name.full %in% missing_admin2 ~ "missing",
admin2.name.full %in% lowVar_admin2 ~ "low variance",
TRUE ~ "none"
)
)
res_map_df_fix <- poly.adm2 %>%
left_join(res_ad2_fix[["res.admin2"]], by = "admin2.name.full") %>%
mutate(
CI_width = direct.upper - direct.lower,
hatch_type = case_when(
admin2.name.full %in% missing_admin2 ~ "missing",
admin2.name.full %in% lowVar_admin2 ~ "low variance",
TRUE ~ "none"
)
)
# 直接估计均值地图
p_res_map_mean <- ggplot(res_map_df) +
geom_sf_pattern(
aes(fill = direct.est, pattern = hatch_type),
pattern_fill = "black",
pattern_alpha = 1,
pattern_density = 0.05,
pattern_spacing = 0.01,
pattern_size = 0.3,
pattern_shape = 16,
color = "black", size = 0.1
) +
scale_fill_viridis_c(
option = "viridis",
direction = -1,
name = "Estimate",
limits = mean_limits,
na.value = "grey90"
) +
scale_pattern_manual(
name = "Data Quality",
values = c("none" = "none", "low variance" = "pch", "missing" = "crosshatch"),
labels = c("none" = "Valid", "low variance" = "Low variance", "missing" = "No cluster sampled")
) +
guides(
fill = guide_colorbar(order = 1),
pattern = guide_legend(order = 2, override.aes = list(fill = "white"))
) +
theme_minimal() +
labs(title = "Direct Estimates by Admin2")
# 修正后的直接估计均值地图
p_res_fix_map_mean <- ggplot(res_map_df_fix) +
geom_sf_pattern(
aes(fill = direct.est, pattern = hatch_type),
pattern_fill = "black",
pattern_alpha = 1,
pattern_density = 0.05,
pattern_spacing = 0.01,
pattern_size = 0.3,
pattern_shape = 16,
color = "black", size = 0.1
) +
scale_fill_viridis_c(
option = "viridis",
direction = -1,
name = "Estimate",
limits = mean_limits,
na.value = "grey90"
) +
scale_pattern_manual(
name = "Data Quality",
values = c("none" = "none", "low variance" = "pch", "missing" = "crosshatch"),
